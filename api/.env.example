# Minimum variables for running the backend
PUBLIC_API_URL=https://anteaterapi.com/v2/rest/
PORT=8080 # must match the /planner/api proxy target in site/next.config.mjs

# --- Required for login + any feature that persists user data ---
# Postgres connection string. With the Docker setup from README step 3, use:
#   postgres://peterportal:peterportal@localhost:5432/peterportal
# DATABASE_URL=
# Long random string (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
# SESSION_SECRET=
# JSON array of emails granted admin privileges after signing in, e.g. ["you@uci.edu"]
# ADMIN_EMAILS=[]

# --- Optional ---
# Required for course/instructor/schedule search (ask in the ICSSC Discord #peterportal channel)
# ANTEATER_API_KEY=

# Secret shared with external services that read user data via the /external endpoints
# EXTERNAL_USER_READ_SECRET=

# --- OIDC (Sign in with Google) ---
# These live in api/.env.local, already committed upstream with values that point at
# ICSSC's shared dev auth provider. Override them here only if you need your own OIDC client.
# OIDC_CLIENT_ID=
# OIDC_ISSUER_URL=
# PRODUCTION_DOMAIN=http://localhost:3000
